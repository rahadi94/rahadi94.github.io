---
layout: null
permalink: /search.json
---
[
  {% assign items = site.pages | concat: site.posts | concat: site.publications | concat: site.portfolio %}
  {% for doc in items %}
  {
    "title": {{ doc.title | jsonify }},
    "url": {{ doc.url | absolute_url | jsonify }},
    "content": {{ doc.content | strip_html | normalize_whitespace | truncate: 1200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]

